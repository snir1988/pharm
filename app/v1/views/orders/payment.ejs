<%- include('../partials/header') %>
<!-- כולל את ההדר המשותף -->
<%- include('../partials/navbar') %>
<!-- כולל את תפריט הניווט -->
<link rel="stylesheet" href="/styles/payment.css" />
<link rel="stylesheet" href="/styles/global.css" />

<div class="payment-container">
  <!-- עטיפת כל עמוד התשלום -->
  <h1>🧾 תשלום על ההזמנה</h1>
  <!-- כותרת הדף -->

  <!-- טופס התשלום -->
  <form action="/order/confirm" method="POST" class="payment-form">
    <!-- שדה חבוי שמעביר את מזהה ההזמנה -->
    <input type="hidden" name="orderId" value="<%= orderId %>" />

    <div class="form-group">
      <label for="cardName">שם בעל הכרטיס:</label>
      <input
        type="text"
        id="cardName"
        name="cardName"
        required
        placeholder="לדוג': ישראל ישראלי"
      />
    </div>

    <div class="form-group">
      <label for="cardNumber">מספר כרטיס:</label>
      <input
        type="text"
        id="cardNumber"
        name="cardNumber"
        required
        pattern="\d{16}"
        placeholder="1234 5678 9012 3456"
      />
    </div>

    <div class="form-row">
      <!-- שורה המחולקת לשני חלקים (תוקף ו-CVV) -->
      <div class="form-group half">
        <label for="expiry">תוקף:</label>
        <input
          type="text"
          id="expiry"
          name="expiry"
          required
          placeholder="MM/YY"
        />
      </div>

      <div class="form-group half">
        <label for="cvv">CVV:</label>
        <input
          type="text"
          id="cvv"
          name="cvv"
          required
          pattern="\d{3}"
          placeholder="123"
        />
      </div>
    </div>

    <button type="submit" class="btn-pay">💳 שלם עכשיו</button>
    <!-- כפתור הגשה -->
  </form>
</div>

<%- include('../partials/footer') %>
<!-- כולל את הפוטר המשותף -->
